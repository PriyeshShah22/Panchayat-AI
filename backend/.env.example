# --- Application ---
APP_NAME="Smart Society Management System"
APP_VERSION="1.0.0"
API_V1_PREFIX=/api/v1
DEBUG=false

# --- Security ---
# IMPORTANT: change this in production to a long random secret
SECRET_KEY=change-me-in-production-please-use-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Database ---
# SQLite default for development. Use Postgres in production.
DATABASE_URL=sqlite:///./smart_society.db
# DATABASE_URL=postgresql+psycopg://soc_admin:soc_password@localhost:5432/smart_society

# --- CORS ---
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost:8080"]

# --- SMTP ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=

# --- AI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-nano
AI_PROVIDER=stub   # set to 'openai' when OPENAI_API_KEY is configured
SARVAM_API_KEY=
# Optional second subscription used only when the primary is rate/credit limited.
SARVAM_FALLBACK_API_KEY=
SARVAM_STT_MODEL=saaras:v3
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- OCR ---
OCR_PROVIDER=stub   # set to 'google_vision' when GOOGLE_VISION_API_KEY is set
GOOGLE_VISION_API_KEY=

# --- Uploads ---
UPLOAD_DIR=uploads
MAX_UPLOAD_BYTES=10485760

# --- Billing ---
DEFAULT_MAINTENANCE_AMOUNT=2500.0
LATE_FEE_PERCENT=2.0

COMPANY_NAME="Green Park Residency"

# --- Schedulers ---
ENABLE_SCHEDULERS=true
